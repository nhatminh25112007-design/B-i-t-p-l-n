# Anaconda Environment Configuration
# -*- coding: utf-8 -*-

# Environment Name
CONDA_ENV_NAME=bai_tap_lon

# Python Version
PYTHON_VERSION=3.9

# Project Settings
PROJECT_NAME=Bài Tập Lớn
PROJECT_PATH=./

# Input/Output Settings
INPUT_FORMAT=int
OUTPUT_FORMAT=formatted

# Calculation Parameters
MONTHS=12
FACTORIAL_INPUT=n
AVERAGE_INPUT=day_so
INTEREST_CALCULATION=true

# Display Settings
LANGUAGE=vi_VN
ENCODING=utf-8
DECIMAL_PLACES=2
